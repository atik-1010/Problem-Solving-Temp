//Divisor list Sum 1 to N 
#include<bits/stdc++.h>
using namespace std;
const int N = 1e6+7;
void io()
{
#ifndef ONLINE_JUDGE
 
    freopen("input.txt", "r", stdin);
    freopen("output.txt", "w", stdout);
 
#endif
}

int sod[N];
void fun(){

    for(int i=1; i<N; i++){
        for(int j=i; j<N; j+=i){
            sod[j]+=i;
        }
    }

    int n;
    cin>>n;
    for(int i=1; i<=n; i++){
        int x; 
        cin>>x;

      cout<<(sod[x]-x)<<endl;

    }

}
int main(){
    io();
    fun();

    return 0;
}
