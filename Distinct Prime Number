//Distinct prime number 
#include<bits/stdc++.h>
using namespace std;
const int N = 1e8;
void io()
{
#ifndef ONLINE_JUDGE
 
    freopen("input.txt", "r", stdin);
    freopen("output.txt", "w", stdout);
 
#endif
}
int fun(int x){
   int res  = 0;
   for(int i=2; i*i<=x; i++){
        if(x%i==0)res++;
        while(x%i==0){
            x/=i;
        }
   }
   if(x>1)res++;
   return res;
}
int main(){
    io();
    int n; 
    cin>>n; 
    int ans=0;
    for(int i=2; i<=n; i++){
        if(fun(i)==2)ans++;
    } 
    cout<<ans<<endl;

    return 0;
}
