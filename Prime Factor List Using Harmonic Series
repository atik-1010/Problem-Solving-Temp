//Prime Factor List Using Harmonic Series 
#include<bits/stdc++.h>
using namespace std;
const int N = 1e6+6;
void io()
{
#ifndef ONLINE_JUDGE
 
    freopen("input.txt", "r", stdin);
    freopen("output.txt", "w", stdout);
 
#endif
}

vector<int>primefactor[N];

bool isprime[N];
void harmonic(){

    for(int i=1; i<N; i++){
        isprime[i]=true;
    }
    for(int i=2; i<N; i++){
        if(isprime[i]==false)continue;
        primefactor[i].push_back(i);
        for(int j=i+i; j<N; j+=i){
            isprime[j]=false;
            int x = j;
            while(x%i==0){
                x/=i;
                primefactor[j].push_back(i);
            }
        }
    }

}
int main(){
    io();

    harmonic();
    for(auto i:primefactor[200])cout<<i<<endl;
    return 0;
}
